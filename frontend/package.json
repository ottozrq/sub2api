    "axios": "^1.16.0",
    "chart.js": "^4.4.1",
    "dompurify": "^3.4.0",
    "driver.js": "^1.4.0",
    "file-saver": "^2.0.5",
    "marked": "^17.0.1",
    "pinia": "^2.1.7",
    "qrcode": "^1.5.4",
    "vue": "^3.4.0",
    "vue-chartjs": "^5.3.0",
    "vue-draggable-plus": "^0.6.1",
    "vue-i18n": "^9.14.5",
