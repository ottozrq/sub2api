    "eslint-plugin-vue": "^10.9.1",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.6.0",
    "vite": "^8.0.13",
    "vite-plugin-checker": "^0.10.3",
